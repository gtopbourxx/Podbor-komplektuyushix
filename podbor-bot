# Проверка совместимости
def check_compatibility(config):
    warnings = []

    # 1. RAM ↔ сокет
    correct_ram = SOCKET_RAM.get(config['CPU']['socket'], None)
    if config['RAM']['type'] != correct_ram:
        warnings.append(f"⚠️ {config['RAM']['type']} несовместима с сокетом {config['CPU']['socket']} (требуется {correct_ram})")

    # 2. Двухканальная RAM
    if config['RAM']['channels'] < 2:
        warnings.append("⚠️ Рекомендуется использовать 2 модуля RAM для двухканального режима.")

    # 3. GPU ↔ корпус (условно проверяем размер)
    if config['GPU']['size_mm'] > 320:
        warnings.append(f"⚠️ GPU {config['GPU']['model']} может не поместиться в стандартный корпус.")

    # 4. Мощность блока питания с запасом 30%
    total_power = config['CPU']['TDP'] + (300 if "RTX" in config['GPU']['model'] else 0) + 50
    recommended_psu = int(total_power * 1.3)
    if config['PSU']['power'] < recommended_psu:
        warnings.append(f"⚠️ Рекомендуемая мощность БП с запасом: {recommended_psu} Вт. Текущий: {config['PSU']['power']} Вт")

    # 5. Минимальные требования для работы
    if config['RAM']['size'] < 16:
        warnings.append("⚠️ Минимум 16 ГБ RAM для комфортной работы.")

    return warnings

# Подбор конфигурации
def recommend_config(task):
    task = task.lower()
    for config in CONFIGS:
        if any(t in task for t in config['tasks']):
            message = f"Рекомендованная конфигурация: {config['name']}\n" \
                      f"CPU: {config['CPU']['model']} (сокет: {config['CPU']['socket']})\n" \
                      f"GPU: {config['GPU']['model']}\n" \
                      f"ОЗУ: {config['RAM']['size']} ГБ {config['RAM']['type']} ({config['RAM']['channels']} канала)\n" \
                      f"SSD: {config['SSD']['size']} ГБ\n" \
                      f"БП: {config['PSU']['power']} Вт, {config['PSU']['cert']}"

            warnings = check_compatibility(config)
            if warnings:
                message += "\n\nПроверка совместимости:\n" + "\n".join(warnings)
            else:
                message += "\n\n✅ Все компоненты совместимы."
            return message
    return "❌ Не удалось подобрать конфигурацию. Уточните задачу."

# Запуск VK LongPoll
vk_session = vk_api.VkApi(token=VK_TOKEN)
longpoll = VkLongPoll(vk_session)
vk = vk_session.get_api()

print("Бот запущен...")

for event in longpoll.listen():
    if event.type == VkEventType.MESSAGE_NEW and event.to_me:
        user_text = event.text
        response = recommend_config(user_text)
        vk.messages.send(
            user_id=event.user_id,
            message=response,
            random_id=0
        )
